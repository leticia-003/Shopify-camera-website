<section class="section">
  <div class="container hero">
    <div class="hero-card">
      <p style="font-weight:700; color: {{ settings.brand_accent }};">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p style="margin-top: 1rem; color:#334155;">{{ section.settings.copy }}</p>
      <div style="margin-top:1.4rem; display:flex; gap:0.8rem; flex-wrap:wrap;">
        <a href="{{ section.settings.primary_link }}" class="btn btn-primary">{{ section.settings.primary_label }}</a>
        <a href="{{ section.settings.secondary_link }}" class="btn btn-secondary">{{ section.settings.secondary_label }}</a>
      </div>
    </div>

    <div>
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading, style: 'border-radius: 20px; border:1px solid rgba(15,23,42,.08); box-shadow: 0 20px 44px rgba(15,23,42,.12);' }}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New season" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Capture moments with style" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Create a premium first impression with a clean, modern storefront optimized for visual products." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop now" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Explore collections" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
