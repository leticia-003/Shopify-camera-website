<section id="reviews" class="section lp-surface">
  <div class="container">
    <div class="lp-section-head" data-reveal>
      <p class="lp-kicker">{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      {% assign summary_parts = section.settings.summary | split: 'based on' %}
      <p class="lp-review-summary">
        <span class="lp-stars lp-stars--icons" aria-hidden="true">
          {% for i in (1..5) %}
            <img src="{{ 'star_yellow.png' | asset_url }}" alt="" loading="lazy" width="24" height="24">
          {% endfor %}
        </span>
        <strong class="lp-review-summary__score">{{ summary_parts[0] | strip }}</strong>
        {% if summary_parts.size > 1 %}
          <span class="lp-review-summary__count">based on {{ summary_parts[1] | strip }}</span>
        {% endif %}
      </p>
    </div>

    <div class="lp-testimonials-grid">
      {% for block in section.blocks %}
        {% assign filled_stars = block.settings.stars | remove: '☆' | size %}
        <article class="lp-testimonial" {{ block.shopify_attributes }} data-reveal>
          <div class="lp-testimonial-top">
            <span class="lp-quote"><img src="{{ 'quotes.png' | asset_url }}" alt="" loading="lazy" width="30" height="30"></span>
            <span class="lp-stars lp-stars--icons" aria-label="{{ block.settings.stars }}">
              {% for i in (1..5) %}
                {% if i <= filled_stars %}
                  <img src="{{ 'star_yellow.png' | asset_url }}" alt="" loading="lazy" width="18" height="18">
                {% else %}
                  <img src="{{ 'star_gray.png' | asset_url }}" alt="" loading="lazy" width="18" height="18">
                {% endif %}
              {% endfor %}
            </span>
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.copy }}</p>
          <div class="lp-testimonial-meta">
            <div>
              <p class="lp-reviewer-name"><strong>{{ block.settings.name }}</strong></p>
              <p class="lp-reviewer-location">{{ block.settings.location }}</p>
            </div>
            <p class="lp-reviewer-when">{{ block.settings.when }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing testimonials",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Customer love" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Join thousands of happy creators who upgraded their content game." },
    { "type": "text", "id": "summary", "label": "Summary", "default": "4.8 out of 5 based on 2,340 reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "stars", "label": "Stars", "default": "★★★★★" },
        { "type": "text", "id": "title", "label": "Title", "default": "Perfect for vlogging on the go" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "The magnetic attachment is super strong and the wireless connection works flawlessly." },
        { "type": "text", "id": "name", "label": "Name", "default": "James K." },
        { "type": "text", "id": "location", "label": "Location", "default": "London, UK" },
        { "type": "text", "id": "when", "label": "Time label", "default": "1 month ago" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing testimonials",
      "blocks": [
        { "type": "review", "settings": { "title": "Game changer for my TikTok videos!", "copy": "I've been struggling with blurry front camera selfies for ages. This little monitor changed everything — I can finally use my rear camera and still see myself. The quality difference is insane. My followers immediately noticed!", "name": "Sarah M.", "location": "Los Angeles, CA", "when": "2 weeks ago" } },
        { "type": "review", "settings": { "title": "Perfect for vlogging on the go", "copy": "The magnetic attachment is super strong and the wireless connection works flawlessly. I was worried about lag but there's literally none. Battery lasts me through a full day of shooting. Highly recommend!", "name": "James K.", "location": "London, UK", "when": "1 month ago" } },
        { "type": "review", "settings": { "title": "Love it — way better than a selfie mirror", "copy": "I tried those cheap clip-on mirrors before and they were useless. This is a real screen that mirrors exactly what your camera sees. The Bluetooth remote is a nice bonus for group photos. Only wish it was slightly bigger.", "name": "Emily R.", "location": "Toronto, CA", "when": "3 weeks ago" } },
        { "type": "review", "settings": { "title": "My content quality went through the roof", "copy": "As a content creator, image quality matters. The rear camera on my iPhone is so much better than the front. This monitor lets me use it for everything - selfies, vlogs, live streams. Worth every penny.", "name": "Mike D.", "location": "New York, NY", "when": "1 week ago" } },
        { "type": "review", "settings": { "title": "So easy to set up, even my mom uses it", "copy": "I bought one for myself and one for my mom who loves FaceTiming and taking photos. The magnetic snap is so satisfying and it connects wirelessly in like 2 seconds. No complicated apps or settings. Just works!", "name": "Lisa T.", "location": "Sydney, AU", "when": "2 months ago" } },
        { "type": "review", "settings": { "title": "Great for real estate photography too", "copy": "I use this for walkthrough videos of properties. Being able to see myself while using the higher quality rear camera makes my videos look so much more professional. Clients have been very impressed. Battery life could be a bit longer for longer shoots.", "name": "Carlos P.", "location": "Miami, FL", "when": "1 month ago", "stars": "★★★★☆" } }
      ]
    }
  ]
}
{% endschema %}
