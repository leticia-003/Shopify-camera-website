<section class="section">
  <div class="container" style="display:grid; grid-template-columns: 1fr 1fr; gap:2rem;">
    <div>
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, loading: 'eager', style: 'border-radius:16px; border:1px solid rgba(15,23,42,.08);' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div style="display:grid; gap:1rem; align-content:start;">
      <h1>{{ product.title }}</h1>
      <p class="price">{{ product.price | money }}</p>
      <div>{{ product.description }}</div>

      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button class="btn btn-primary" type="submit" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
